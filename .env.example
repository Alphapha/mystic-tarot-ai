# ============== Mystic Tarot AI 环境配置 ==============
# 复制本文件为 .env,并填入真实值后即可启用 AI 解读
# 不配置也能运行,程序会自动降级为本地解读模式

# 是否启用 AI 解读(true / false)
AI_ENABLED=false

# OpenAI API Key(切勿提交真实 Key 到仓库)
OPENAI_API_KEY=

# 如使用代理或兼容服务(如 Azure、各类中转),可修改 Base URL
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的模型名
OPENAI_MODEL=gpt-4o-mini
